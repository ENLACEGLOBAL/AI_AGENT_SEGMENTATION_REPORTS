FROM python:3.11-slim

WORKDIR /app

# Instalar dependencias del sistema para ReportLab y otras librerías
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libfreetype6 \
    libpng16-16 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app

ENV PYTHONUNBUFFERED=1 \
    UVICORN_WORKERS=2 \
    APP_HOST=0.0.0.0 \
    APP_PORT=8000

EXPOSE 8000
CMD ["uvicorn", "src.rta_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
